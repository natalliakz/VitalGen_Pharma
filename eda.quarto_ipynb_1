    "# Time series analysis of enrollment trends\n",
    "# Parse dates and create monthly aggregations\n",
    "enrollment_ts = (\n",
    "    enrollment\n",
    "    .with_columns([\n",
    "        pl.col(\"enrollment_date\").str.strptime(pl.Date, \"%Y-%m-%d\")\n",
    "    ])\n",
    "    .group_by(\"enrollment_date\")\n",
    "    .agg([\n",
    "        pl.col(\"monthly_enrolled\").sum().alias(\"total_enrolled\")\n",
    "    ])\n",
    "    .sort(\"enrollment_date\")\n",
    ")\n",
    "\n",
    "# Calculate cumulative enrollment\n",
    "enrollment_ts = enrollment_ts.with_columns([\n",
    "    pl.col(\"total_enrolled\").cum_sum().alias(\"cumulative_total\")\n",
    "])\n",
    "\n",
    "print(enrollment_ts.head(10))\n",
    "\n",
    "# Visualization\n",
    "ts_df = enrollment_ts.to_pandas()\n",
    "fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 10))\n",
    "\n",
    "# Monthly enrollment\n",
    "ax1.plot(ts_df[\"enrollment_date\"], ts_df[\"total_enrolled\"], color=\"#003D7A\", linewidth=2)\n",
    "ax1.fill_between(ts_df[\"enrollment_date\"], ts_df[\"total_enrolled\"], alpha=0.3, color=\"#003D7A\")\n",
    "ax1.set_ylabel(\"Patients Enrolled\")\n",
    "ax1.set_title(\"Monthly Patient Enrollment Over Time\", fontsize=14, fontweight=\"bold\")\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# Cumulative enrollment\n",
    "ax2.plot(ts_df[\"enrollment_date\"], ts_df[\"cumulative_total\"], color=\"#00A3A1\", linewidth=2)\n",
    "ax2.fill_between(ts_df[\"enrollment_date\"], ts_df[\"cumulative_total\"], alpha=0.3, color=\"#00A3A1\")\n",
    "ax2.set_xlabel(\"Date\")\n",
    "ax2.set_ylabel(\"Cumulative Patients\")\n",
    "ax2.set_title(\"Cumulative Patient Enrollment Over Time\", fontsize=14, fontweight=\"bold\")\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
