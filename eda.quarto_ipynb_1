   "source": [
    "# Calculate enrollment metrics by trial using polars\n",
    "enrollment_summary = (\n",
    "    enrollment\n",
    "    .group_by(\"trial_id\")\n",
    "    .agg([\n",
    "        pl.col(\"cumulative_enrolled\").max().alias(\"actual_enrollment\"),\n",
    "        pl.col(\"target_per_site\").first().alias(\"target_per_site\"),\n",
    "        pl.col(\"month\").max().alias(\"months_elapsed\")\n",
    "    ])\n",
    "    .join(trials.select([\"trial_id\", \"phase\", \"therapeutic_area\", \"target_enrollment\"]), on=\"trial_id\")\n",
    ")\n",
    "\n",
    "# Calculate enrollment rate per site per month\n",
    "enrollment_summary = enrollment_summary.with_columns([\n",
    "    (pl.col(\"actual_enrollment\") / pl.col(\"target_enrollment\") * 100).alias(\"pct_of_target\"),\n",
    "    (pl.col(\"actual_enrollment\") / pl.col(\"months_elapsed\")).alias(\"enrollment_rate_per_month\")\n",
    "])\n",
    "\n",
    "print(enrollment_summary.head())"
   ]
