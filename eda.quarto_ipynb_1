   ],
   "source": [
    "# Using polars for data manipulation (similar to dplyr in R)\n",
    "portfolio_summary = (\n",
    "    trials\n",
    "    .group_by(\"phase\")\n",
    "    .agg([\n",
    "        pl.count(\"trial_id\").alias(\"n_trials\"),\n",
    "        pl.col(\"target_enrollment\").sum().alias(\"total_target\"),\n",
    "        pl.col(\"n_sites\").sum().alias(\"total_sites\"),\n",
    "        pl.col(\"target_enrollment\").mean().alias(\"avg_target\")\n",
    "    ])\n",
    "    .sort(\"phase\")\n",
    ")\n",
    "\n",
    "print(portfolio_summary)"
   ]
